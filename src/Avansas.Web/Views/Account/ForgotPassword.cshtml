@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="bg-white rounded-3 shadow-sm p-4 mt-4">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary">avansas</h2>
                    <h5>Şifre Sıfırlama</h5>
                    <p class="text-muted small">E-posta adresinizi girin, size şifre sıfırlama bağlantısı gönderelim.</p>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    </div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">E-posta Adresi</label>
                        <input type="email" name="email" class="form-control" placeholder="ornek@email.com" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 btn-lg">Sıfırlama Bağlantısı Gönder</button>
                </form>

                <hr class="my-4" />
                <div class="text-center">
                    <a href="/hesap/giris" class="text-decoration-none small">
                        <i class="fas fa-arrow-left me-1"></i>Giriş sayfasına dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
