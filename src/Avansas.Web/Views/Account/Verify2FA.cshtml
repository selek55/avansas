@{
    ViewData["Title"] = "İki Faktörlü Doğrulama";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <i class="fas fa-mobile-alt text-primary" style="font-size:2.5rem;"></i>
                    <h3 class="mt-3 mb-1">Doğrulama Kodu</h3>
                    <p class="text-muted">Authenticator uygulamanızdaki 6 haneli kodu girin.</p>

                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                        <div class="my-3">
                            <input type="text" name="code" class="form-control form-control-lg text-center"
                                   maxlength="6" placeholder="000000" autocomplete="one-time-code" autofocus />
                        </div>
                        <div class="form-check text-start mb-3">
                            <input class="form-check-input" type="checkbox" name="rememberMe" id="rememberMe" />
                            <label class="form-check-label" for="rememberMe">Bu tarayıcıyı hatırla</label>
                        </div>
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger py-2">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <small>@error.ErrorMessage</small>
                                }
                            </div>
                        }
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-sign-in-alt me-2"></i>Giriş Yap
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
