@model Avansas.Application.DTOs.OrderDto
@{
    ViewData["Title"] = "Sipariş #" + Model.OrderNumber;
}

<div class="container">
    <div class="row g-4">
        <div class="col-lg-3">
            <div class="bg-white rounded-3 shadow-sm p-3">
                <nav class="nav flex-column gap-1">
                    <a href="/hesap/profile" class="nav-link text-dark px-3 py-2"><i class="fas fa-user me-2"></i> Profilim</a>
                    <a href="/hesap/orders" class="nav-link active px-3 py-2 rounded-2 bg-primary text-white">
                        <i class="fas fa-box me-2"></i> Siparişlerim
                    </a>
                    <a href="/hesap/addresses" class="nav-link text-dark px-3 py-2"><i class="fas fa-map-marker-alt me-2"></i> Adreslerim</a>
                    <form method="post" action="/hesap/logout" class="mt-2">
                        <button type="submit" class="nav-link text-danger px-3 py-2 btn btn-link w-100 text-start">
                            <i class="fas fa-sign-out-alt me-2"></i> Çıkış Yap
                        </button>
                    </form>
                </nav>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">Sipariş #@Model.OrderNumber</h5>
                <a href="/hesap/fatura/@Model.OrderNumber" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-file-pdf me-1"></i>Fatura İndir
                </a>
                @{
                    var badge = Model.Status switch {
                        Avansas.Domain.Enums.OrderStatus.Pending => "warning",
                        Avansas.Domain.Enums.OrderStatus.Confirmed => "info",
                        Avansas.Domain.Enums.OrderStatus.Shipped => "primary",
                        Avansas.Domain.Enums.OrderStatus.Delivered => "success",
                        Avansas.Domain.Enums.OrderStatus.Cancelled => "danger",
                        _ => "secondary"
                    };
                }
                <span class="badge bg-@badge fs-6">@Model.StatusText</span>
            </div>

            @if (!string.IsNullOrEmpty(Model.CargoTrackingNumber))
            {
                <div class="alert alert-info small mb-3">
                    <i class="fas fa-truck me-2"></i>
                    Kargo: <strong>@Model.CargoCompany</strong> — Takip No: <strong>@Model.CargoTrackingNumber</strong>
                </div>
            }

            <div class="bg-white rounded-3 shadow-sm mb-4">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr><th>Ürün</th><th class="text-center">Adet</th><th class="text-end">Toplam</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="@(item.ProductImageUrl ?? "/images/no-image.png")"
                                                 style="width:48px;height:48px;object-fit:contain" />
                                            <div>
                                                <div class="fw-semibold small">@item.ProductName</div>
                                                <div class="text-muted" style="font-size:.75rem">@item.UnitPrice.ToString("N2")₺ / adet</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center align-middle">@item.Quantity</td>
                                    <td class="text-end align-middle fw-semibold">@item.TotalPrice.ToString("N2")₺</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr><td colspan="2" class="text-end text-muted small">Ara Toplam</td><td class="text-end">@Model.SubTotal.ToString("N2")₺</td></tr>
                            <tr><td colspan="2" class="text-end text-muted small">Kargo</td><td class="text-end">@(Model.ShippingCost == 0 ? "Ücretsiz" : Model.ShippingCost.ToString("N2") + "₺")</td></tr>
                            @if (Model.DiscountAmount > 0) {
                                <tr><td colspan="2" class="text-end text-muted small">İndirim</td><td class="text-end text-danger">-@Model.DiscountAmount.ToString("N2")₺</td></tr>
                            }
                            <tr><td colspan="2" class="text-end fw-bold">Toplam</td><td class="text-end fw-bold text-primary">@Model.Total.ToString("N2")₺</td></tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <div class="bg-white rounded-3 shadow-sm p-3 small">
                        <div class="fw-semibold mb-2">Teslimat Adresi</div>
                        <p class="mb-1 text-muted">@Model.ShippingAddress</p>
                        <p class="mb-0 text-muted">@Model.ShippingCity</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="bg-white rounded-3 shadow-sm p-3 small">
                        <div class="fw-semibold mb-2">Ödeme</div>
                        <p class="mb-1">@Model.PaymentMethodText</p>
                        @{
                            var pb = Model.PaymentStatus switch {
                                Avansas.Domain.Enums.PaymentStatus.Paid => "success",
                                Avansas.Domain.Enums.PaymentStatus.Failed => "danger",
                                _ => "warning"
                            };
                        }
                        <span class="badge bg-@pb">@Model.PaymentStatusText</span>
                    </div>
                </div>
            </div>

            <a href="/hesap/orders" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i> Siparişlerime Dön
            </a>
        </div>
    </div>
</div>
