@model Avansas.Application.DTOs.PagedResult<Avansas.Application.DTOs.OrderDto>
@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container">
    <div class="row g-4">
        <div class="col-lg-3">
            <div class="bg-white rounded-3 shadow-sm p-3">
                <nav class="nav flex-column gap-1">
                    <a href="/hesap/profile" class="nav-link text-dark px-3 py-2">
                        <i class="fas fa-user me-2"></i> Profilim
                    </a>
                    <a href="/hesap/orders" class="nav-link active px-3 py-2 rounded-2 bg-primary text-white">
                        <i class="fas fa-box me-2"></i> Siparişlerim
                    </a>
                    <a href="/hesap/addresses" class="nav-link text-dark px-3 py-2">
                        <i class="fas fa-map-marker-alt me-2"></i> Adreslerim
                    </a>
                    <form method="post" action="/hesap/logout" class="mt-2">
                        <button type="submit" class="nav-link text-danger px-3 py-2 btn btn-link w-100 text-start">
                            <i class="fas fa-sign-out-alt me-2"></i> Çıkış Yap
                        </button>
                    </form>
                </nav>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="bg-white rounded-3 shadow-sm p-4">
                <h5 class="fw-bold mb-4">Siparişlerim</h5>

                @if (!Model.Items.Any())
                {
                    <div class="text-center py-5">
                        <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Henüz siparişiniz yok.</p>
                        <a href="/urunler" class="btn btn-primary">Alışverişe Başla</a>
                    </div>
                }
                else
                {
                    @foreach (var order in Model.Items)
                    {
                        var badge = order.Status switch {
                                Avansas.Domain.Enums.OrderStatus.Pending => "warning",
                                Avansas.Domain.Enums.OrderStatus.Confirmed => "info",
                                Avansas.Domain.Enums.OrderStatus.Shipped => "primary",
                                Avansas.Domain.Enums.OrderStatus.Delivered => "success",
                                Avansas.Domain.Enums.OrderStatus.Cancelled => "danger",
                                _ => "secondary"
                            };
                        <div class="border rounded-2 p-3 mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div>
                                    <span class="fw-semibold">#@order.OrderNumber</span>
                                    <span class="text-muted small ms-2">@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                                <span class="badge bg-@badge">@order.StatusText</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                @foreach (var item in order.Items.Take(3))
                                {
                                    <img src="@(item.ProductImageUrl ?? "/images/no-image.png")"
                                         style="width:40px;height:40px;object-fit:contain;border:1px solid #eee;border-radius:4px" />
                                }
                                @if (order.Items.Count > 3)
                                {
                                    <span class="text-muted small">+@(order.Items.Count - 3) ürün daha</span>
                                }
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-primary">@order.Total.ToString("N2")₺</span>
                                <div class="d-flex gap-2">
                                    <form method="post" action="/hesap/tekrar-siparis/@order.Id">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">
                                            <i class="fas fa-redo me-1"></i>Tekrar Sipariş
                                        </button>
                                    </form>
                                    <a href="/hesap/orderdetail?orderNumber=@order.OrderNumber" class="btn btn-sm btn-outline-primary">
                                        Detay <i class="fas fa-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-3">
                            <ul class="pagination pagination-sm justify-content-center">
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                        <a class="page-link" href="?page=@i">@i</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</div>
