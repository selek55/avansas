@model Avansas.Application.DTOs.RegisterDto
@{
    ViewData["Title"] = "Üye Ol";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="bg-white rounded-3 shadow-sm p-4 mt-4">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary">avansas</h2>
                    <h5>Hemen Üye Olun</h5>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-semibold">Ad *</label>
                            <input asp-for="FirstName" class="form-control" placeholder="Adınız" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-semibold">Soyad *</label>
                            <input asp-for="LastName" class="form-control" placeholder="Soyadınız" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">E-posta *</label>
                        <input asp-for="Email" class="form-control" placeholder="ornek@email.com" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-semibold">Telefon</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="05XX XXX XX XX" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label fw-semibold">Şifre *</label>
                            <input asp-for="Password" type="password" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Şifre Tekrar *</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="IsCorporate" class="form-check-input" type="checkbox" id="isCorporate"
                                   onchange="document.getElementById('corporateFields').style.display=this.checked?'block':'none'" />
                            <label asp-for="IsCorporate" class="form-check-label">Kurumsal Hesap</label>
                        </div>
                    </div>
                    <div id="corporateFields" style="display:none">
                        <div class="row g-3 mb-3 p-3 border rounded bg-light">
                            <div class="col-md-12">
                                <label asp-for="CompanyName" class="form-label fw-semibold">Şirket Adı</label>
                                <input asp-for="CompanyName" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="TaxNumber" class="form-label fw-semibold">Vergi No</label>
                                <input asp-for="TaxNumber" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="TaxOffice" class="form-label fw-semibold">Vergi Dairesi</label>
                                <input asp-for="TaxOffice" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="terms" required />
                            <label class="form-check-label small" for="terms">
                                <a href="#" class="text-decoration-none">Kullanım Koşullarını</a> ve
                                <a href="#" class="text-decoration-none">Gizlilik Politikasını</a> okudum, kabul ediyorum.
                            </label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 btn-lg">Üye Ol</button>
                </form>

                <hr class="my-4" />
                <div class="text-center">
                    <p class="text-muted mb-2">Zaten hesabınız var mı?</p>
                    <a href="/hesap/giris" class="btn btn-outline-primary w-100">Giriş Yap</a>
                </div>
            </div>
        </div>
    </div>
</div>
