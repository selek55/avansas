@using Avansas.Application.Interfaces
@model ShipmentTrackingDto
@{
    ViewData["Title"] = "Kargo Takip";
}

<div class="container py-4">
    <h2 class="mb-4"><i class="fas fa-truck me-2"></i>Kargo Takip</h2>

    @if (Model != null)
    {
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <partial name="_ShipmentTimeline" model="Model" />
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <i class="fas fa-search text-muted" style="font-size:3rem;"></i>
                <h4 class="mt-3 text-muted">Kargo Bilgisi Bulunamadı</h4>
                <p class="text-muted">Girdiğiniz takip numarası ile ilgili kargo bilgisi bulunamadı.</p>
                <a asp-action="Index" asp-controller="Home" class="btn btn-primary mt-2">Ana Sayfaya Dön</a>
            </div>
        </div>
    }
</div>
