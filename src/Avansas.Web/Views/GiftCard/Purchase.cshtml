@{
    ViewData["Title"] = "Hediye Kartı Satın Al";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="mb-4"><i class="fas fa-gift text-primary me-2"></i>Hediye Kartı</h2>
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                { <div>@e.ErrorMessage</div> }
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tutar (₺)</label>
                            <select name="amount" class="form-select">
                                <option value="50">50 ₺</option>
                                <option value="100" selected>100 ₺</option>
                                <option value="250">250 ₺</option>
                                <option value="500">500 ₺</option>
                                <option value="1000">1.000 ₺</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Alıcı E-posta</label>
                            <input type="email" name="recipientEmail" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Alıcı Adı (opsiyonel)</label>
                            <input type="text" name="recipientName" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Kişisel Mesaj (opsiyonel)</label>
                            <textarea name="personalMessage" class="form-control" rows="3"
                                      placeholder="Sevgili..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-gift me-2"></i>Hediye Kartı Oluştur
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
