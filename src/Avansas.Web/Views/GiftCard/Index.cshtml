@{
    ViewData["Title"] = "Hediye Kartı";
}

<div class="container py-4">
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center p-5">
                    <i class="fas fa-gift text-primary" style="font-size:3rem;"></i>
                    <h4 class="mt-3">Hediye Kartı Satın Al</h4>
                    <p class="text-muted">Sevdiklerinize özel bir hediye verin!</p>
                    <a asp-action="Purchase" class="btn btn-primary">
                        <i class="fas fa-shopping-cart me-2"></i>Hediye Kartı Al
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4">
                    <h5><i class="fas fa-search me-2"></i>Bakiye Sorgula</h5>
                    <div class="input-group mt-3">
                        <input type="text" id="giftCardCode" class="form-control"
                               placeholder="Hediye kartı kodu (16 hane)" maxlength="16" />
                        <button class="btn btn-outline-primary" onclick="checkBalance()">Sorgula</button>
                    </div>
                    <div id="balanceResult" class="mt-3 d-none"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    async function checkBalance() {
        const code = document.getElementById('giftCardCode').value.trim();
        if (!code) return;
        const res = await fetch(`/hediye-karti/CheckBalance?code=${encodeURIComponent(code)}`);
        const data = await res.json();
        const el = document.getElementById('balanceResult');
        el.classList.remove('d-none');
        if (data.success) {
            el.innerHTML = `<div class="alert alert-success">Mevcut Bakiye: <strong>${data.balance.toFixed(2)} ₺</strong><br><small>Son Kullanım: ${data.expiresAt}</small></div>`;
        } else {
            el.innerHTML = `<div class="alert alert-danger">Geçersiz hediye kartı kodu.</div>`;
        }
    }
</script>
