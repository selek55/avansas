@if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Admin") && !User.IsInRole("Manager"))
{
<!-- Chat Widget -->
<div id="chatWidget">
    <!-- Toggle Button -->
    <button id="chatToggle" onclick="toggleChat()" class="btn btn-primary rounded-circle shadow-lg"
            style="position:fixed;bottom:24px;right:24px;width:56px;height:56px;z-index:9999;font-size:1.4rem;">
        <i class="fas fa-comments" id="chatIcon"></i>
    </button>

    <!-- Chat Window -->
    <div id="chatWindow" style="display:none;position:fixed;bottom:90px;right:24px;width:360px;max-height:480px;z-index:9998;border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.2);">
        <div class="bg-primary text-white px-4 py-3 d-flex justify-content-between align-items-center">
            <div>
                <div class="fw-bold"><i class="fas fa-headset me-2"></i>Canli Destek</div>
                <small class="opacity-75" id="chatConnectionStatus">Baglaniyor...</small>
            </div>
            <button class="btn btn-sm text-white" onclick="toggleChat()"><i class="fas fa-times"></i></button>
        </div>
        <div id="chatMessages" class="bg-white p-3" style="height:320px;overflow-y:auto;">
            <div class="text-center text-muted small py-4">
                <i class="fas fa-comment-dots fa-2x mb-2 d-block"></i>
                Merhaba! Size nasil yardimci olabiliriz?
            </div>
        </div>
        <div class="bg-white border-top p-2">
            <form id="chatForm" class="d-flex gap-2">
                <input type="text" id="chatInput" class="form-control form-control-sm" placeholder="Mesajinizi yazin..." />
                <button type="submit" class="btn btn-primary btn-sm px-3"><i class="fas fa-paper-plane"></i></button>
            </form>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    let chatOpen = false;
    let chatConnection = null;
    let chatStarted = false;

    function toggleChat() {
        chatOpen = !chatOpen;
        document.getElementById('chatWindow').style.display = chatOpen ? 'block' : 'none';
        document.getElementById('chatIcon').className = chatOpen ? 'fas fa-times' : 'fas fa-comments';
        if (!chatStarted) startChat();
    }

    function startChat() {
        chatStarted = true;
        chatConnection = new signalR.HubConnectionBuilder()
            .withUrl("/chathub")
            .withAutomaticReconnect()
            .build();

        chatConnection.start().then(() => {
            document.getElementById('chatConnectionStatus').textContent = 'Cevrimici';
        }).catch(() => {
            document.getElementById('chatConnectionStatus').textContent = 'Baglanti hatasi';
        });

        chatConnection.on("ReceiveMessage", (data) => {
            const container = document.getElementById('chatMessages');
            const isMe = !data.isAdmin;
            container.innerHTML += `
                <div class="mb-2 d-flex ${data.isAdmin ? 'justify-content-start' : 'justify-content-end'}">
                    <div class="px-3 py-2 rounded-3 ${data.isAdmin ? 'bg-light' : 'bg-primary text-white'}" style="max-width:80%">
                        ${data.isAdmin ? `<div class="small fw-semibold">${data.user}</div>` : ''}
                        <div class="small">${data.message}</div>
                        <div class="text-end" style="font-size:.65rem;opacity:.7;">${data.timestamp}</div>
                    </div>
                </div>`;
            container.scrollTop = container.scrollHeight;
        });

        chatConnection.onreconnecting(() => {
            document.getElementById('chatConnectionStatus').textContent = 'Yeniden baglaniyor...';
        });
        chatConnection.onreconnected(() => {
            document.getElementById('chatConnectionStatus').textContent = 'Cevrimici';
        });
    }

    document.getElementById('chatForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const input = document.getElementById('chatInput');
        const msg = input.value.trim();
        if (!msg || !chatConnection) return;
        chatConnection.invoke("SendMessage", msg);
        input.value = '';
    });
</script>
}
