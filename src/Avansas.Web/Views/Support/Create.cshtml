@model CreateTicketDto
@{
    ViewData["Title"] = "Yeni Destek Talebi";
}

<div class="container">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
            <li class="breadcrumb-item"><a href="/destek">Destek Taleplerim</a></li>
            <li class="breadcrumb-item active">Yeni Talep</li>
        </ol>
    </nav>

    <h2 class="fw-bold mb-4"><i class="fas fa-plus-circle me-2 text-primary"></i>Yeni Destek Talebi</h2>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form method="post" action="/destek/olustur">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Konu <span class="text-danger">*</span></label>
                            <input type="text" name="Subject" class="form-control" value="@Model?.Subject"
                                   placeholder="Talebinizin konusunu yazınız" required />
                            <span asp-validation-for="Subject" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Sipariş Numarası <small class="text-muted">(Opsiyonel)</small></label>
                            <input type="number" name="OrderId" class="form-control" value="@Model?.OrderId"
                                   placeholder="Siparişle ilgiliyse sipariş ID'sini giriniz" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mesajınız <span class="text-danger">*</span></label>
                            <textarea name="Message" class="form-control" rows="6"
                                      placeholder="Sorununuzu veya talebinizi detaylı şekilde açıklayınız..." required>@Model?.Message</textarea>
                            <span asp-validation-for="Message" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-2"></i>Talebi Gönder
                            </button>
                            <a href="/destek" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Geri Dön
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
