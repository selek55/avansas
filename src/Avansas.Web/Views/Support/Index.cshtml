@model List<TicketDto>
@{
    ViewData["Title"] = "Destek Taleplerim";
}

<div class="container">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
            <li class="breadcrumb-item"><a href="/hesap">Hesabım</a></li>
            <li class="breadcrumb-item active">Destek Taleplerim</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="fas fa-headset me-2 text-primary"></i>Destek Taleplerim</h2>
        <a href="/destek/olustur" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Yeni Talep Oluştur
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <i class="fas fa-ticket-alt fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">Henüz destek talebiniz bulunmuyor.</h5>
                <a href="/destek/olustur" class="btn btn-primary mt-3">
                    <i class="fas fa-plus me-2"></i>Yeni Talep Oluştur
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Konu</th>
                            <th>Durum</th>
                            <th>Öncelik</th>
                            <th>Tarih</th>
                            <th>Mesaj Sayısı</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ticket in Model)
                        {
                            string statusBadge = ticket.Status switch
                            {
                                TicketStatus.Open => "bg-success",
                                TicketStatus.InProgress => "bg-info",
                                TicketStatus.WaitingCustomer => "bg-warning text-dark",
                                TicketStatus.Resolved => "bg-secondary",
                                TicketStatus.Closed => "bg-dark",
                                _ => "bg-secondary"
                            };
                            string priorityBadge = ticket.Priority switch
                            {
                                TicketPriority.Low => "bg-secondary",
                                TicketPriority.Normal => "bg-info",
                                TicketPriority.High => "bg-warning text-dark",
                                TicketPriority.Urgent => "bg-danger",
                                _ => "bg-secondary"
                            };
                            <tr>
                                <td class="text-muted">@ticket.Id</td>
                                <td>
                                    <a href="/destek/@ticket.Id" class="text-decoration-none fw-semibold">@ticket.Subject</a>
                                    @if (ticket.OrderNumber != null)
                                    {
                                        <br /><small class="text-muted">Sipariş: @ticket.OrderNumber</small>
                                    }
                                </td>
                                <td><span class="badge @statusBadge">@ticket.StatusText</span></td>
                                <td><span class="badge @priorityBadge">@ticket.PriorityText</span></td>
                                <td><small class="text-muted">@ticket.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small></td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border">@ticket.MessageCount</span>
                                </td>
                                <td>
                                    <a href="/destek/@ticket.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
