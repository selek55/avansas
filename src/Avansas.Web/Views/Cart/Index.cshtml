@model Avansas.Application.DTOs.CartDto
@{
    ViewData["Title"] = "Sepetim";
}

<div class="container">
    <h2 class="fw-bold mb-4">Sepetim</h2>

    @if (Model == null || !Model.Items.Any())
    {
        <div class="text-center py-5 bg-white rounded-3 shadow-sm">
            <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">Sepetiniz boş</h4>
            <p class="text-muted mb-4">Alışverişe başlamak için ürün ekleyin.</p>
            <a href="/urunler" class="btn btn-primary btn-lg">Alışverişe Başla</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="bg-white rounded-3 shadow-sm">
                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex align-items-center gap-3 p-3 border-bottom cart-item" id="item-@item.Id">
                            <img src="@(item.ProductImageUrl ?? "/images/no-image.png")"
                                 style="width:80px;height:80px;object-fit:contain" alt="@item.ProductName" />
                            <div class="flex-fill">
                                <a href="/urun/@item.ProductSlug" class="fw-semibold text-decoration-none text-dark">
                                    @item.ProductName
                                </a>
                                <div class="text-muted small">SKU: @item.ProductSKU</div>
                                <div class="fw-bold text-primary">@item.UnitPrice.ToString("N2")₺</div>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <div class="input-group" style="width:110px">
                                    <button class="btn btn-outline-secondary btn-sm"
                                            onclick="updateQty(@item.Id, @(item.Quantity - 1))">-</button>
                                    <input type="number" class="form-control form-control-sm text-center"
                                           value="@item.Quantity" min="1" id="qty-@item.Id" readonly />
                                    <button class="btn btn-outline-secondary btn-sm"
                                            onclick="updateQty(@item.Id, @(item.Quantity + 1))">+</button>
                                </div>
                                <div class="fw-bold" style="min-width:80px">@item.TotalPrice.ToString("N2")₺</div>
                                <button class="btn btn-outline-danger btn-sm"
                                        onclick="removeItem(@item.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="bg-white rounded-3 shadow-sm p-4 sticky-top" style="top:80px">
                    <h5 class="fw-bold mb-4">Sipariş Özeti</h5>

                    <!-- Coupon -->
                    <div class="mb-4">
                        <div class="input-group">
                            <input type="text" id="couponCode" class="form-control" placeholder="Kupon kodu"
                                   value="@Model.CouponCode" />
                            <button class="btn btn-outline-secondary" onclick="applyCoupon()">Uygula</button>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.CouponCode))
                        {
                            <form method="post" action="/sepet/removecoupon">
                                <button type="submit" class="btn btn-sm btn-outline-danger mt-1">
                                    <i class="fas fa-times me-1"></i> Kuponu Kaldır
                                </button>
                            </form>
                        }
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ara Toplam</span>
                        <span class="fw-semibold" id="subTotal">@Model.SubTotal.ToString("N2")₺</span>
                    </div>
                    @if (Model.DiscountAmount > 0)
                    {
                        <div class="d-flex justify-content-between mb-2 text-success">
                            <span>İndirim</span>
                            <span>-@Model.DiscountAmount.ToString("N2")₺</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between mb-2 text-muted small">
                        <span>Kargo</span>
                        <span>@(Model.SubTotal >= 500 ? "Ücretsiz" : "29,90₺")</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold fs-5">Toplam</span>
                        <span class="fw-bold fs-5 text-primary" id="total">@Model.Total.ToString("N2")₺</span>
                    </div>
                    <a href="/odeme" class="btn btn-primary w-100 btn-lg">
                        <i class="fas fa-lock me-2"></i> Güvenli Ödemeye Geç
                    </a>
                    <a href="/urunler" class="btn btn-outline-secondary w-100 mt-2">
                        <i class="fas fa-arrow-left me-2"></i> Alışverişe Devam Et
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
async function updateQty(itemId, qty) {
    if (qty < 1) { removeItem(itemId); return; }
    const res = await fetch('/sepet/update', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({cartItemId: itemId, quantity: qty})
    });
    const data = await res.json();
    if (data.success) location.reload();
}

async function removeItem(itemId) {
    const res = await fetch('/sepet/remove?cartItemId=' + itemId, {
        method: 'POST', headers: {'Content-Type':'application/json'}
    });
    const data = await res.json();
    if (data.success) location.reload();
}

async function applyCoupon() {
    const code = document.getElementById('couponCode').value;
    const res = await fetch('/sepet/applycoupon?couponCode=' + encodeURIComponent(code), {
        method: 'POST', headers: {'Content-Type':'application/json'}
    });
    const data = await res.json();
    if (data.success) location.reload();
    else alert(data.message);
}
</script>
}
