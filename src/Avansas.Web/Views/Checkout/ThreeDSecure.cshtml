@{
    ViewData["Title"] = "3D Güvenli Ödeme";
    Layout = null; // 3DS form tam ekran çalışır
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>3D Güvenli Ödeme — Avansas</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f5f5f5; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .card { background: #fff; padding: 32px; border-radius: 8px; box-shadow: 0 2px 16px rgba(0,0,0,.1); max-width: 480px; width: 100%; text-align: center; }
        .spinner { display: inline-block; width: 40px; height: 40px; border: 4px solid #e0e0e0; border-top-color: #007bff; border-radius: 50%; animation: spin .8s linear infinite; margin: 16px auto; }
        @@keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="card">
        <h2>3D Güvenli Ödeme</h2>
        <div class="spinner"></div>
        <p>Bankanızın doğrulama sayfasına yönlendiriliyorsunuz...</p>
    </div>
    @Html.Raw(ViewBag.HtmlContent)
</body>
</html>
