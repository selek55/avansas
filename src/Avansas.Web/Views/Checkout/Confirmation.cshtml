@model Avansas.Application.DTOs.OrderDto
@{
    ViewData["Title"] = "Sipariş Onaylandı";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center py-5">
                <div class="mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success"
                         style="width:80px;height:80px">
                        <i class="fas fa-check fa-2x text-white"></i>
                    </div>
                </div>
                <h2 class="fw-bold mb-2">Siparişiniz Alındı!</h2>
                <p class="text-muted mb-1">Sipariş numaranız: <strong class="text-primary">#@Model.OrderNumber</strong></p>
                <p class="text-muted">Onay e-postası <strong>@Model.UserEmail</strong> adresine gönderildi.</p>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold">Sipariş Detayları</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <img src="@(item.ProductImageUrl ?? "/images/no-image.png")"
                                                     style="width:48px;height:48px;object-fit:contain" />
                                                <div>
                                                    <div class="fw-semibold small">@item.ProductName</div>
                                                    <div class="text-muted" style="font-size:.75rem">@item.ProductSKU</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center align-middle text-muted small">x@item.Quantity</td>
                                        <td class="text-end align-middle fw-semibold">@item.TotalPrice.ToString("N2")₺</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr><td colspan="2" class="text-end text-muted small">Ara Toplam</td><td class="text-end">@Model.SubTotal.ToString("N2")₺</td></tr>
                                <tr><td colspan="2" class="text-end text-muted small">Kargo</td><td class="text-end">@(Model.ShippingCost == 0 ? "Ücretsiz" : Model.ShippingCost.ToString("N2") + "₺")</td></tr>
                                @if (Model.DiscountAmount > 0) {
                                    <tr><td colspan="2" class="text-end text-muted small">İndirim</td><td class="text-end text-danger">-@Model.DiscountAmount.ToString("N2")₺</td></tr>
                                }
                                <tr><td colspan="2" class="text-end fw-bold">Toplam</td><td class="text-end fw-bold fs-5 text-primary">@Model.Total.ToString("N2")₺</td></tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white fw-semibold small">Teslimat Adresi</div>
                        <div class="card-body small">
                            <p class="mb-1">@Model.ShippingAddress</p>
                            <p class="text-muted mb-0">@Model.ShippingCity</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white fw-semibold small">Ödeme Bilgisi</div>
                        <div class="card-body small">
                            <p class="mb-1">@Model.PaymentMethodText</p>
                            <p class="mb-0">
                                @{
                                    var badge = Model.PaymentStatus switch {
                                        Avansas.Domain.Enums.PaymentStatus.Paid => "success",
                                        Avansas.Domain.Enums.PaymentStatus.Failed => "danger",
                                        _ => "warning"
                                    };
                                }
                                <span class="badge bg-@badge">@Model.PaymentStatusText</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-center">
                <a href="/hesap/orders" class="btn btn-primary">
                    <i class="fas fa-list me-2"></i> Siparişlerim
                </a>
                <a href="/urunler" class="btn btn-outline-secondary">
                    <i class="fas fa-shopping-bag me-2"></i> Alışverişe Devam
                </a>
            </div>
        </div>
    </div>
</div>
