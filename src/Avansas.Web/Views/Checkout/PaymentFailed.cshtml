@{
    ViewData["Title"] = "Ödeme Başarısız";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body py-5">
                    <i class="fas fa-times-circle text-danger" style="font-size:4rem;"></i>
                    <h2 class="mt-3 text-danger">Ödeme Başarısız</h2>
                    <p class="text-muted">@(TempData["Error"] ?? "Ödeme işleminiz gerçekleştirilemedi.")</p>
                    <div class="d-flex gap-3 justify-content-center mt-4">
                        <a asp-action="Index" asp-controller="Checkout" class="btn btn-primary">
                            <i class="fas fa-redo me-1"></i> Tekrar Dene
                        </a>
                        <a asp-action="Index" asp-controller="Cart" class="btn btn-outline-secondary">
                            <i class="fas fa-shopping-cart me-1"></i> Sepete Dön
                        </a>
                    </div>
                    @if (ViewBag.OrderId != null)
                    {
                        <p class="mt-3 text-muted small">Sipariş No: #@ViewBag.OrderId</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
