@using Avansas.Application.DTOs
@model List<ProductListDto>
@{
    ViewData["Title"] = "İstek Listem";
}

<div class="container py-4">
    <h3 class="fw-bold mb-4"><i class="fas fa-heart text-danger me-2"></i>İstek Listem
        <span class="badge bg-light text-dark fs-6 ms-2">@Model.Count ürün</span>
    </h3>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-heart-broken fa-4x text-muted mb-3"></i>
            <h5 class="text-muted">İstek listeniz boş</h5>
            <p class="text-muted">Beğendiğiniz ürünleri istek listenize ekleyin.</p>
            <a href="/urunler" class="btn btn-primary mt-2"><i class="fas fa-shopping-bag me-2"></i>Ürünlere Göz At</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var p in Model)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm border-0">
                        <a href="/urun/@p.Slug">
                            <img src="@(p.MainImageUrl ?? "/images/no-image.png")" class="card-img-top"
                                 style="height:180px;object-fit:contain;padding:8px;" alt="@p.Name" />
                        </a>
                        <div class="card-body p-3">
                            <a href="/urun/@p.Slug" class="text-decoration-none text-dark">
                                <p class="card-text small fw-semibold mb-1" style="line-height:1.3">@p.Name</p>
                            </a>
                            <div class="fw-bold text-primary">
                                @if (p.DiscountedPrice.HasValue && p.DiscountedPrice.Value < p.Price)
                                {
                                    <span class="text-muted text-decoration-line-through small me-1">@p.Price.ToString("N2")₺</span>
                                    @p.DiscountedPrice.Value.ToString("N2")<span class="small">₺</span>
                                }
                                else
                                {
                                    @p.Price.ToString("N2")<span class="small">₺</span>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 p-3 pt-0 d-flex gap-2">
                            <button class="btn btn-primary btn-sm flex-fill add-to-cart-btn"
                                    data-product-id="@p.Id"
                                    @(p.StockQuantity == 0 ? "disabled" : "")>
                                <i class="fas fa-cart-plus me-1"></i>Sepete Ekle
                            </button>
                            <form method="post" asp-action="Remove" asp-controller="Wishlist">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@p.Id" />
                                <button class="btn btn-outline-danger btn-sm" title="Kaldır">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
        const res = await fetch('/sepet/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: parseInt(btn.dataset.productId), quantity: 1 })
        });
        const data = await res.json();
        if (data.success) {
            document.getElementById('cartCount').textContent = data.itemCount;
            document.getElementById('cartCount').style.display = '';
        }
        alert(data.message);
    });
});
</script>
}
