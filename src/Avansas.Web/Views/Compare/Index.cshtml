@model List<ProductDto>
@{
    ViewData["Title"] = "Karşılaştırma";
}

<div class="container">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
            <li class="breadcrumb-item active">Karşılaştırma</li>
        </ol>
    </nav>

    <h2 class="fw-bold mb-4"><i class="fas fa-columns me-2 text-primary"></i>Karşılaştırma</h2>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <i class="fas fa-balance-scale fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">Karşılaştırma listeniz boş</h5>
                <p class="text-muted">Ürünleri karşılaştırmak için ürün sayfalarından "Karşılaştır" butonunu kullanabilirsiniz.</p>
                <a href="/urunler" class="btn btn-primary mt-2">
                    <i class="fas fa-shopping-bag me-2"></i>Ürünlere Göz At
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-bordered align-middle text-center mb-0">
                    <!-- Images Row -->
                    <tr>
                        <th class="bg-light text-start" style="min-width:140px;">Görsel</th>
                        @foreach (var p in Model)
                        {
                            <td style="min-width:200px;">
                                <img src="@(p.MainImageUrl ?? "/images/no-image.png")" alt="@p.Name"
                                     class="img-fluid rounded" style="max-height:160px; object-fit:contain;" />
                            </td>
                        }
                    </tr>
                    <!-- Name Row -->
                    <tr>
                        <th class="bg-light text-start">Ürün Adı</th>
                        @foreach (var p in Model)
                        {
                            <td>
                                <a href="/urun/@p.Slug" class="text-decoration-none fw-semibold">@p.Name</a>
                            </td>
                        }
                    </tr>
                    <!-- Price Row -->
                    <tr>
                        <th class="bg-light text-start">Fiyat</th>
                        @foreach (var p in Model)
                        {
                            <td>
                                @if (p.DiscountedPrice.HasValue && p.DiscountedPrice < p.Price)
                                {
                                    <span class="text-decoration-line-through text-muted small">@p.Price.ToString("N2") ₺</span>
                                    <br />
                                    <span class="fw-bold text-danger fs-5">@p.EffectivePrice.ToString("N2") ₺</span>
                                }
                                else
                                {
                                    <span class="fw-bold fs-5">@p.EffectivePrice.ToString("N2") ₺</span>
                                }
                            </td>
                        }
                    </tr>
                    <!-- Brand Row -->
                    <tr>
                        <th class="bg-light text-start">Marka</th>
                        @foreach (var p in Model)
                        {
                            <td>@(p.BrandName ?? "-")</td>
                        }
                    </tr>
                    <!-- Category Row -->
                    <tr>
                        <th class="bg-light text-start">Kategori</th>
                        @foreach (var p in Model)
                        {
                            <td>@(p.CategoryName ?? "-")</td>
                        }
                    </tr>
                    <!-- Stock Row -->
                    <tr>
                        <th class="bg-light text-start">Stok Durumu</th>
                        @foreach (var p in Model)
                        {
                            <td>
                                @if (p.StockQuantity > 0)
                                {
                                    <span class="badge bg-success"><i class="fas fa-check me-1"></i>Stokta (@p.StockQuantity)</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Tükendi</span>
                                }
                            </td>
                        }
                    </tr>
                    <!-- Rating Row -->
                    <tr>
                        <th class="bg-light text-start">Değerlendirme</th>
                        @foreach (var p in Model)
                        {
                            <td>
                                @if (p.ReviewCount > 0)
                                {
                                    <span class="text-warning">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= Math.Round(p.AverageRating))
                                            {
                                                <i class="fas fa-star"></i>
                                            }
                                            else
                                            {
                                                <i class="far fa-star"></i>
                                            }
                                        }
                                    </span>
                                    <br />
                                    <small class="text-muted">(@p.ReviewCount değerlendirme)</small>
                                }
                                else
                                {
                                    <small class="text-muted">Henüz değerlendirilmedi</small>
                                }
                            </td>
                        }
                    </tr>
                    <!-- SKU Row -->
                    <tr>
                        <th class="bg-light text-start">SKU</th>
                        @foreach (var p in Model)
                        {
                            <td class="text-muted small">@p.SKU</td>
                        }
                    </tr>
                    <!-- Actions Row -->
                    <tr>
                        <th class="bg-light text-start">İşlemler</th>
                        @foreach (var p in Model)
                        {
                            <td>
                                <div class="d-flex flex-column gap-2">
                                    <button class="btn btn-sm btn-primary" onclick="addToCart(@p.Id)">
                                        <i class="fas fa-cart-plus me-1"></i>Sepete Ekle
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="removeFromCompare(@p.Id)">
                                        <i class="fas fa-trash me-1"></i>Kaldır
                                    </button>
                                </div>
                            </td>
                        }
                    </tr>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    function addToCart(productId) {
        fetch('/sepet/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: productId, quantity: 1 })
        }).then(r => r.json()).then(data => {
            if (data.success) {
                const el = document.getElementById('cartCount');
                if (el) { el.textContent = data.cartItemCount; el.style.display = ''; }
                alert('Ürün sepete eklendi!');
            }
        });
    }

    function removeFromCompare(productId) {
        fetch('/karsilastir/sil', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(productId)
        }).then(r => r.json()).then(data => {
            if (data.success) location.reload();
        });
    }
</script>
}
