@{
    ViewData["Title"] = "Sunucu Hatası";
}
<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div style="font-size:8rem;font-weight:900;color:#e9ecef;line-height:1;">500</div>
            <i class="fas fa-exclamation-triangle fa-3x text-danger mb-3"></i>
            <h2 class="fw-bold mb-2">Bir Hata Oluştu</h2>
            <p class="text-muted mb-4">Sunucumuzda beklenmedik bir hata meydana geldi. Ekibimiz bilgilendirildi, en kısa sürede düzeltilecek.</p>
            <div class="d-flex gap-2 justify-content-center">
                <a href="/" class="btn btn-primary"><i class="fas fa-home me-2"></i>Ana Sayfaya Dön</a>
                <button onclick="history.back()" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Geri Git</button>
            </div>
        </div>
    </div>
</div>
