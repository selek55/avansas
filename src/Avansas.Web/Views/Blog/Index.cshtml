@model PagedResult<BlogPostDto>
@{
    ViewData["Title"] = "Blog";
    var categories = ViewBag.Categories as List<BlogCategoryDto> ?? new List<BlogCategoryDto>();
    int? selectedCategoryId = ViewBag.SelectedCategoryId as int?;
}

<div class="container">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
            <li class="breadcrumb-item active">Blog</li>
        </ol>
    </nav>

    <h2 class="fw-bold mb-4"><i class="fas fa-blog me-2 text-primary"></i>Blog</h2>

    <div class="row">
        <!-- Blog Posts -->
        <div class="col-lg-9">
            @if (!Model.Items.Any())
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>Henüz yayınlanmış yazı bulunmuyor.
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var post in Model.Items)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card shadow-sm h-100 border-0">
                                @if (!string.IsNullOrEmpty(post.ImageUrl))
                                {
                                    <img src="@post.ImageUrl" class="card-img-top" alt="@post.Title"
                                         style="height:200px; object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center" style="height:200px;">
                                        <i class="fas fa-image fa-3x text-muted"></i>
                                    </div>
                                }
                                <div class="card-body d-flex flex-column">
                                    @if (!string.IsNullOrEmpty(post.CategoryName))
                                    {
                                        <span class="badge bg-primary mb-2 align-self-start">@post.CategoryName</span>
                                    }
                                    <h5 class="card-title">
                                        <a href="/blog/@post.Slug" class="text-decoration-none text-dark">@post.Title</a>
                                    </h5>
                                    @if (!string.IsNullOrEmpty(post.Summary))
                                    {
                                        <p class="card-text text-muted small flex-fill">@post.Summary</p>
                                    }
                                    <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
                                        <small class="text-muted">
                                            <i class="fas fa-user me-1"></i>@post.AuthorName
                                        </small>
                                        <small class="text-muted">
                                            <i class="fas fa-calendar me-1"></i>@(post.PublishedAt?.ToString("dd MMM yyyy") ?? post.CreatedAt.ToString("dd MMM yyyy"))
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link" href="/blog?page=@(Model.PageNumber - 1)@(selectedCategoryId.HasValue ? $"&categoryId={selectedCategoryId}" : "")">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a class="page-link" href="/blog?page=@i@(selectedCategoryId.HasValue ? $"&categoryId={selectedCategoryId}" : "")">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link" href="/blog?page=@(Model.PageNumber + 1)@(selectedCategoryId.HasValue ? $"&categoryId={selectedCategoryId}" : "")">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="fas fa-folder me-2"></i>Kategoriler
                </div>
                <div class="list-group list-group-flush">
                    <a href="/blog" class="list-group-item list-group-item-action @(selectedCategoryId == null ? "active" : "")">
                        Tümü
                    </a>
                    @foreach (var cat in categories)
                    {
                        <a href="/blog?categoryId=@cat.Id"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(selectedCategoryId == cat.Id ? "active" : "")">
                            @cat.Name
                            <span class="badge bg-secondary rounded-pill">@cat.PostCount</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
