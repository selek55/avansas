@model Avansas.Application.DTOs.PagedResult<Avansas.Application.DTOs.ProductListDto>
@{
    ViewData["Title"] = "Ürünler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var filter = ViewBag.Filter as Avansas.Application.DTOs.ProductFilterDto ?? new Avansas.Application.DTOs.ProductFilterDto();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex gap-2">
        <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="fas fa-exchange-alt me-1"></i> Toplu Islem
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/admin/products/exportproducts"><i class="fas fa-file-export me-2 text-success"></i>Urunleri Disari Aktar (Excel)</a></li>
                <li><a class="dropdown-item" href="/admin/products/importproducts"><i class="fas fa-file-import me-2 text-primary"></i>Toplu Urun Icerik Aktarimi</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" href="/admin/products/downloadtemplate"><i class="fas fa-download me-2 text-muted"></i>Sablon Indir</a></li>
            </ul>
        </div>
    </div>
    <a href="/admin/products/create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i> Yeni Urun Ekle
    </a>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <input type="text" name="SearchTerm" class="form-control" placeholder="Ürün adı veya SKU..."
                       value="@filter.SearchTerm" />
            </div>
            <div class="col-md-2">
                <select name="IsActive" class="form-select">
                    <option value="">Tüm Durumlar</option>
                    <option value="true" selected="@(filter.IsActive == true ? "selected" : null)">Aktif</option>
                    <option value="false" selected="@(filter.IsActive == false ? "selected" : null)">Pasif</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Ara</button>
            </div>
            <div class="col-md-2">
                <a href="/admin/products" class="btn btn-outline-secondary w-100">Temizle</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <span class="text-muted small">Toplam <strong>@Model.TotalCount</strong> ürün</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ürün</th>
                        <th>SKU</th>
                        <th>Kategori</th>
                        <th>Fiyat</th>
                        <th>Stok</th>
                        <th>Durum</th>
                        <th>Tarih</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="@(p.MainImageUrl ?? "/images/no-image.png")"
                                         style="width:40px;height:40px;object-fit:contain" alt="@p.Name" />
                                    <div>
                                        <div class="fw-semibold small">@p.Name</div>
                                        @if (p.IsFeatured) { <span class="badge bg-warning text-dark" style="font-size:.65rem">Öne Çıkan</span> }
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted small">@p.BrandName</td>
                            <td class="small">@p.CategoryName</td>
                            <td>
                                @if (p.DiscountedPrice.HasValue && p.DiscountedPrice.Value < p.Price)
                                {
                                    <div class="text-decoration-line-through text-muted small">@p.Price.ToString("N2")₺</div>
                                    <div class="fw-bold text-danger">@p.EffectivePrice.ToString("N2")₺</div>
                                }
                                else { <span class="fw-semibold">@p.Price.ToString("N2")₺</span> }
                            </td>
                            <td>
                                <span class="@(p.StockQuantity > 10 ? "text-success" : p.StockQuantity > 0 ? "text-warning" : "text-danger") fw-semibold">
                                    @p.StockQuantity
                                </span>
                            </td>
                            <td>
                                <span class="badge @(p.IsActive ? "bg-success" : "bg-secondary")">
                                    @(p.IsActive ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td class="text-muted small">@p.CreatedAt.ToString("dd.MM.yy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/admin/products/edit/@p.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" action="/admin/products/delete/@p.Id"
                                          onsubmit="return confirm('Silmek istediğinizden emin misiniz?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-white">
            <nav><ul class="pagination pagination-sm mb-0 justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" href="?PageNumber=@i&SearchTerm=@filter.SearchTerm">@i</a>
                    </li>
                }
            </ul></nav>
        </div>
    }
</div>
