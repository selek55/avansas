@model Avansas.Application.DTOs.UpdateProductDto
@using Avansas.Application.DTOs
@{
    ViewData["Title"] = "Ürün Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var productImages = ViewBag.ProductImages as IEnumerable<ProductImageDto> ?? Enumerable.Empty<ProductImageDto>();
    var variants = ViewBag.Variants as List<ProductVariantDto> ?? new List<ProductVariantDto>();
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form method="post" enctype="multipart/form-data">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label fw-semibold">Ürün Adı *</label>
                            <input asp-for="Name" class="form-control" id="nameInput" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Slug" class="form-label fw-semibold">
                                Slug <small class="text-muted fw-normal">(URL adresi)</small>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text text-muted small">/urun/</span>
                                <input asp-for="Slug" class="form-control" id="slugInput" />
                            </div>
                            <div class="mt-1 small">
                                <span class="text-muted">Önizleme: </span>
                                <a id="slugPreview" href="#" target="_blank" class="text-primary text-decoration-none fst-italic">/urun/</a>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="SKU" class="form-label fw-semibold">SKU *</label>
                            <input asp-for="SKU" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label fw-semibold">Fiyat (₺) *</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DiscountedPrice" class="form-label fw-semibold">İndirimli Fiyat (₺)</label>
                            <input asp-for="DiscountedPrice" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StockQuantity" class="form-label fw-semibold">Stok</label>
                            <input asp-for="StockQuantity" class="form-control" type="number" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TaxRate" class="form-label fw-semibold">KDV Oranı (%)</label>
                            <select asp-for="TaxRate" class="form-select">
                                <option value="0">%0</option>
                                <option value="1">%1</option>
                                <option value="8">%8</option>
                                <option value="18">%18</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CategoryId" class="form-label fw-semibold">Kategori *</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                                <option value="">Seçiniz</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="ShortDescription" class="form-label fw-semibold">Kısa Açıklama</label>
                            <input asp-for="ShortDescription" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold">Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Ana Görseli Değiştir</label>
                            <div id="dropZone" class="border rounded-3 p-3 text-center" style="border-style:dashed!important;cursor:pointer;background:#f8f9fa;transition:background .2s">
                                <div id="dropZoneContent">
                                    @if (!string.IsNullOrEmpty(Model.MainImageUrl))
                                    {
                                        <img src="@Model.MainImageUrl" class="img-fluid rounded mb-2" style="max-height:120px;object-fit:contain;" />
                                        <p class="mb-0 small text-muted">Yeni görsel seçmek için tıkla veya sürükle</p>
                                    }
                                    else
                                    {
                                        <i class="fas fa-cloud-upload-alt fa-2x text-muted mb-2"></i>
                                        <p class="mb-1 text-muted">Dosyayı sürükle-bırak veya tıkla</p>
                                        <small class="text-muted">JPG, PNG, WEBP — maks. 10MB</small>
                                    }
                                </div>
                                <img id="imagePreview" src="" alt="" class="img-fluid rounded" style="max-height:150px;display:none;" />
                                <input type="file" name="mainImageFile" id="mainImageFile" accept="image/*" class="d-none" />
                            </div>
                            <div id="imageError" class="text-danger small mt-1"></div>
                            <input asp-for="MainImageUrl" type="hidden" />
                        </div>

                        <div class="col-md-4">
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label">Aktif</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                                <label asp-for="IsFeatured" class="form-check-label">Öne Çıkan</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsNewProduct" class="form-check-input" type="checkbox" />
                                <label asp-for="IsNewProduct" class="form-check-label">Yeni Ürün</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="fas fa-save me-2"></i> Güncelle
                        </button>
                        <a href="/admin/products" class="btn btn-outline-secondary px-4">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-3">
                <h6 class="mb-0 fw-semibold">Görsel Galerisi</h6>
                <small class="text-muted">Sürükleyerek sırala · Ana görseli seç · Sil</small>
            </div>
            <div class="card-body">
                <div id="galleryDropZone" class="border rounded-3 p-3 text-center mb-3" style="border-style:dashed!important;cursor:pointer;background:#f8f9fa;transition:background .2s">
                    <i class="fas fa-plus text-muted"></i>
                    <span class="text-muted ms-2 small">Görsel ekle</span>
                    <input type="file" id="galleryFileInput" accept="image/*" multiple class="d-none" />
                </div>
                <div id="galleryUploadProgress" class="d-none mb-2">
                    <div class="progress" style="height:4px">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" style="width:100%"></div>
                    </div>
                    <small class="text-muted">Yükleniyor...</small>
                </div>
                <div id="galleryError" class="text-danger small mb-2"></div>

                <div id="imageGallery" class="d-flex flex-wrap gap-2">
                    @foreach (var img in productImages)
                    {
                        <div class="gallery-item position-relative" data-id="@img.Id" data-url="@img.ImageUrl" style="width:80px;height:80px;cursor:grab">
                            <img src="@img.ImageUrl" class="img-fluid rounded w-100 h-100" style="object-fit:cover;" />
                            @if (img.IsMain)
                            {
                                <span class="badge bg-success position-absolute top-0 start-0 m-1" style="font-size:.55rem">Ana</span>
                            }
                            <div class="gallery-actions position-absolute top-0 end-0 d-none flex-column gap-1 m-1">
                                @if (!img.IsMain)
                                {
                                    <button type="button" class="btn btn-xs btn-success py-0 px-1 btn-set-main" data-id="@img.Id" title="Ana yap" style="font-size:.65rem">
                                        <i class="fas fa-star"></i>
                                    </button>
                                }
                                <button type="button" class="btn btn-xs btn-danger py-0 px-1 btn-delete-img" data-id="@img.Id" data-url="@img.ImageUrl" title="Sil" style="font-size:.65rem">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
                <small class="text-muted d-block mt-2">
                    <i class="fas fa-info-circle me-1"></i>Görselin üzerine gelin, seçenekler görünsün.
                </small>
            </div>
        </div>
    </div>
</div>

<!-- Varyantlar Section -->
<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-transparent border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="fas fa-layer-group me-2"></i>Varyantlar</h6>
        <button type="button" class="btn btn-sm btn-primary" id="btnShowAddVariant">
            <i class="fas fa-plus me-1"></i>Varyant Ekle
        </button>
    </div>
    <div class="card-body">
        <!-- Add Variant Inline Form (hidden by default) -->
        <div id="addVariantForm" class="border rounded p-3 mb-3" style="display:none;background:#f8f9fa;">
            <form method="post" asp-area="Admin" asp-controller="Products" asp-action="AddVariant" asp-route-productId="@Model.Id">
                <div class="row g-2 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">Ad</label>
                        <input name="Name" class="form-control form-control-sm" placeholder="Renk, Boyut..." required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">Deger</label>
                        <input name="Value" class="form-control form-control-sm" placeholder="Kirmizi, A4..." required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">SKU</label>
                        <input name="SKU" class="form-control form-control-sm" placeholder="SKU" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">Fiyat Fark (TL)</label>
                        <input name="PriceAdjustment" type="number" step="0.01" value="0" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label small fw-semibold">Stok</label>
                        <input name="StockQuantity" type="number" value="0" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label small fw-semibold">Aktif</label>
                        <div class="form-check form-switch mt-1">
                            <input name="IsActive" type="checkbox" value="true" checked class="form-check-input" />
                        </div>
                    </div>
                    <div class="col-md-2 d-flex gap-1">
                        <button type="submit" class="btn btn-sm btn-success"><i class="fas fa-check"></i></button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="btnCancelAddVariant"><i class="fas fa-times"></i></button>
                    </div>
                </div>
            </form>
        </div>

        @if (variants.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ad</th>
                            <th>Deger</th>
                            <th>SKU</th>
                            <th>Fiyat Farki</th>
                            <th>Stok</th>
                            <th>Aktif</th>
                            <th style="width:80px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in variants)
                        {
                            <tr>
                                <td>@v.Name</td>
                                <td>@v.Value</td>
                                <td><code>@v.SKU</code></td>
                                <td>
                                    @if (v.PriceAdjustment > 0)
                                    {
                                        <span class="text-success">+@v.PriceAdjustment.ToString("N2")TL</span>
                                    }
                                    else if (v.PriceAdjustment < 0)
                                    {
                                        <span class="text-danger">@v.PriceAdjustment.ToString("N2")TL</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>@v.StockQuantity</td>
                                <td>
                                    @if (v.IsActive)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Pasif</span>
                                    }
                                </td>
                                <td>
                                    <form method="post" asp-area="Admin" asp-controller="Products" asp-action="DeleteVariant"
                                          asp-route-id="@v.Id" asp-route-productId="@Model.Id"
                                          onsubmit="return confirm('Bu varyant silinsin mi?');" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted text-center mb-0 small">Henuz varyant eklenmemis.</p>
        }
    </div>
</div>

@section Scripts {
<script>
(function() {
    const productId = @Model.Id;

    // Slug
    const nameEl = document.getElementById('nameInput');
    const slugEl = document.getElementById('slugInput');
    let manual = slugEl.value !== '';
    function toSlug(v) {
        return v.toLowerCase()
            .replace(/ş/g,'s').replace(/ğ/g,'g').replace(/ü/g,'u')
            .replace(/ö/g,'o').replace(/ç/g,'c').replace(/ı/g,'i').replace(/İ/g,'i')
            .replace(/\s+/g,'-').replace(/[^a-z0-9\-]/g,'').replace(/-+/g,'-');
    }
    const preview = document.getElementById('slugPreview');
    function updatePreview(slug) { preview.textContent = '/urun/' + (slug || '...'); preview.href = '/urun/' + slug; }
    nameEl.addEventListener('input', () => { if (!manual) { slugEl.value = toSlug(nameEl.value); updatePreview(slugEl.value); } });
    slugEl.addEventListener('input', () => { manual = slugEl.value !== ''; slugEl.value = toSlug(slugEl.value); updatePreview(slugEl.value); });
    updatePreview(slugEl.value);

    // Main image drop zone
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('mainImageFile');
    const imgPreview = document.getElementById('imagePreview');
    const dropContent = document.getElementById('dropZoneContent');
    const imgError = document.getElementById('imageError');
    const maxSize = 10 * 1024 * 1024;
    const allowed = ['image/jpeg','image/jpg','image/png','image/webp','image/gif'];

    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.style.background = '#e9ecef'; });
    dropZone.addEventListener('dragleave', () => { dropZone.style.background = '#f8f9fa'; });
    dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.style.background = '#f8f9fa'; if (e.dataTransfer.files[0]) handleMainFile(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', () => { if (fileInput.files[0]) handleMainFile(fileInput.files[0]); });

    function handleMainFile(file) {
        imgError.textContent = '';
        if (!allowed.includes(file.type)) { imgError.textContent = 'Desteklenmeyen format.'; return; }
        if (file.size > maxSize) { imgError.textContent = 'Dosya 10MB\'dan büyük.'; return; }
        const reader = new FileReader();
        reader.onload = e => { imgPreview.src = e.target.result; imgPreview.style.display = 'block'; dropContent.style.display = 'none'; };
        reader.readAsDataURL(file);
        const dt = new DataTransfer(); dt.items.add(file); fileInput.files = dt.files;
    }

    // Gallery
    const galleryDrop = document.getElementById('galleryDropZone');
    const galleryInput = document.getElementById('galleryFileInput');
    const galleryEl = document.getElementById('imageGallery');
    const galleryProgress = document.getElementById('galleryUploadProgress');
    const galleryError = document.getElementById('galleryError');

    galleryDrop.addEventListener('click', () => galleryInput.click());
    galleryDrop.addEventListener('dragover', e => { e.preventDefault(); galleryDrop.style.background = '#e9ecef'; });
    galleryDrop.addEventListener('dragleave', () => { galleryDrop.style.background = '#f8f9fa'; });
    galleryDrop.addEventListener('drop', e => { e.preventDefault(); galleryDrop.style.background = '#f8f9fa'; uploadFiles(e.dataTransfer.files); });
    galleryInput.addEventListener('change', () => { uploadFiles(galleryInput.files); galleryInput.value = ''; });

    async function uploadFiles(files) {
        galleryError.textContent = '';
        for (const file of files) {
            if (!allowed.includes(file.type)) { galleryError.textContent = `${file.name}: desteklenmeyen format.`; continue; }
            if (file.size > maxSize) { galleryError.textContent = `${file.name}: 10MB'dan büyük.`; continue; }
            galleryProgress.classList.remove('d-none');
            const form = new FormData(); form.append('file', file);
            try {
                const res = await fetch(`/admin/media/upload/${productId}`, { method: 'POST', body: form });
                const data = await res.json();
                if (!res.ok) { galleryError.textContent = data.error; continue; }
                addGalleryItem(data);
            } catch { galleryError.textContent = 'Yükleme hatası.'; }
        }
        galleryProgress.classList.add('d-none');
    }

    function addGalleryItem(img) {
        const div = document.createElement('div');
        div.className = 'gallery-item position-relative';
        div.dataset.id = img.id;
        div.dataset.url = img.url;
        div.style.cssText = 'width:80px;height:80px;cursor:grab';
        div.innerHTML = `
            <img src="${img.url}" class="img-fluid rounded w-100 h-100" style="object-fit:cover;" />
            <div class="gallery-actions position-absolute top-0 end-0 d-none flex-column gap-1 m-1">
                <button type="button" class="btn btn-xs btn-success py-0 px-1 btn-set-main" data-id="${img.id}" title="Ana yap" style="font-size:.65rem"><i class="fas fa-star"></i></button>
                <button type="button" class="btn btn-xs btn-danger py-0 px-1 btn-delete-img" data-id="${img.id}" data-url="${img.url}" title="Sil" style="font-size:.65rem"><i class="fas fa-trash"></i></button>
            </div>`;
        galleryEl.appendChild(div);
        bindItemEvents(div);
    }

    // Hover actions
    function bindItemEvents(el) {
        const actions = el.querySelector('.gallery-actions');
        el.addEventListener('mouseenter', () => actions && actions.classList.replace('d-none', 'd-flex'));
        el.addEventListener('mouseleave', () => actions && actions.classList.replace('d-flex', 'd-none'));
    }
    document.querySelectorAll('.gallery-item').forEach(bindItemEvents);

    // Delete
    galleryEl.addEventListener('click', async e => {
        const btnDel = e.target.closest('.btn-delete-img');
        if (btnDel) {
            if (!confirm('Bu görsel silinsin mi?')) return;
            const id = btnDel.dataset.id;
            const url = btnDel.dataset.url;
            const res = await fetch(`/admin/media/delete/${id}?fileUrl=${encodeURIComponent(url)}`, { method: 'POST' });
            if (res.ok) btnDel.closest('.gallery-item').remove();
            else galleryError.textContent = 'Silme hatası.';
        }
        const btnMain = e.target.closest('.btn-set-main');
        if (btnMain) {
            const id = btnMain.dataset.id;
            const res = await fetch(`/admin/media/set-main/${productId}/${id}`, { method: 'POST' });
            if (res.ok) {
                document.querySelectorAll('.gallery-item').forEach(item => {
                    const badge = item.querySelector('.badge');
                    if (badge) badge.remove();
                    const actions = item.querySelector('.gallery-actions');
                    if (actions && !actions.querySelector('.btn-set-main')) {
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'btn btn-xs btn-success py-0 px-1 btn-set-main';
                        btn.dataset.id = item.dataset.id;
                        btn.title = 'Ana yap';
                        btn.style.fontSize = '.65rem';
                        btn.innerHTML = '<i class="fas fa-star"></i>';
                        actions.prepend(btn);
                    }
                });
                const thisItem = btnMain.closest('.gallery-item');
                thisItem.querySelector('.gallery-actions').querySelector('.btn-set-main')?.remove();
                const badge = document.createElement('span');
                badge.className = 'badge bg-success position-absolute top-0 start-0 m-1';
                badge.style.fontSize = '.55rem';
                badge.textContent = 'Ana';
                thisItem.appendChild(badge);
            } else galleryError.textContent = 'Ana görsel atama hatası.';
        }
    });

    // Drag-to-reorder (simple HTML5)
    let dragSrc = null;
    galleryEl.addEventListener('dragstart', e => {
        dragSrc = e.target.closest('.gallery-item');
        if (dragSrc) { e.dataTransfer.effectAllowed = 'move'; dragSrc.style.opacity = '0.4'; }
    });
    galleryEl.addEventListener('dragover', e => {
        e.preventDefault(); e.dataTransfer.dropEffect = 'move';
        const target = e.target.closest('.gallery-item');
        if (target && target !== dragSrc) target.style.outline = '2px solid #0d6efd';
    });
    galleryEl.addEventListener('dragleave', e => {
        const target = e.target.closest('.gallery-item');
        if (target) target.style.outline = '';
    });
    galleryEl.addEventListener('drop', async e => {
        e.preventDefault();
        const target = e.target.closest('.gallery-item');
        if (target && target !== dragSrc && dragSrc) {
            target.style.outline = '';
            galleryEl.insertBefore(dragSrc, target);
            await saveOrder();
        }
    });
    galleryEl.addEventListener('dragend', e => {
        const item = e.target.closest('.gallery-item');
        if (item) item.style.opacity = '';
        document.querySelectorAll('.gallery-item').forEach(i => i.style.outline = '');
    });
    document.querySelectorAll('.gallery-item').forEach(i => i.draggable = true);

    async function saveOrder() {
        const ids = [...document.querySelectorAll('.gallery-item')].map(i => parseInt(i.dataset.id));
        await fetch(`/admin/media/reorder/${productId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(ids)
        });
    }

    // Variant form toggle
    document.getElementById('btnShowAddVariant')?.addEventListener('click', () => {
        document.getElementById('addVariantForm').style.display = '';
    });
    document.getElementById('btnCancelAddVariant')?.addEventListener('click', () => {
        document.getElementById('addVariantForm').style.display = 'none';
    });
})();
</script>
}
