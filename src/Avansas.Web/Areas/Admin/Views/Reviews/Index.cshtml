@using Avansas.Application.DTOs
@model PagedResult<ReviewDto>
@{
    ViewData["Title"] = "Yorumlar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Yorumlar</h4>
    <div class="d-flex gap-2">
        <a href="?isApproved=" class="btn btn-sm @(ViewBag.IsApprovedFilter == null ? "btn-primary" : "btn-outline-secondary")">Tümü</a>
        <a href="?isApproved=false" class="btn btn-sm @(ViewBag.IsApprovedFilter == false ? "btn-warning" : "btn-outline-warning")">Bekleyenler</a>
        <a href="?isApproved=true" class="btn btn-sm @(ViewBag.IsApprovedFilter == true ? "btn-success" : "btn-outline-success")">Onaylılar</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Ürün</th>
                    <th>Kullanıcı</th>
                    <th>Puan</th>
                    <th>Yorum</th>
                    <th>Durum</th>
                    <th>Tarih</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Items)
                {
                    <tr>
                        <td class="small">@r.ProductName</td>
                        <td class="small">@r.UserFullName</td>
                        <td>
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fas fa-star @(i <= r.Rating ? "text-warning" : "text-muted")" style="font-size:.7rem;"></i>
                            }
                        </td>
                        <td class="small" style="max-width:200px;">
                            @if (!string.IsNullOrEmpty(r.Title)) { <strong>@r.Title</strong><br /> }
                            <span class="text-muted">@r.Comment</span>
                        </td>
                        <td>
                            @if (r.IsApproved)
                            {
                                <span class="badge bg-success">Onaylı</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Bekliyor</span>
                            }
                        </td>
                        <td class="small text-muted">@r.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td>
                            <div class="d-flex gap-1">
                                @if (!r.IsApproved)
                                {
                                    <form method="post" asp-action="Approve" asp-route-id="@r.Id">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-success" title="Onayla">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </form>
                                }
                                <form method="post" asp-action="Delete" asp-route-id="@r.Id"
                                      onsubmit="return confirm('Bu yorum silinsin mi?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-danger" title="Sil">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Yorum bulunamadı.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
