@model Avansas.Application.DTOs.OrderDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Fatura - @Model.OrderNumber</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-size: 14px; color: #333; padding: 40px; }
        .invoice { max-width: 800px; margin: 0 auto; }

        .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 3px solid #1a1a2e; }
        .company-name { font-size: 28px; font-weight: 700; color: #1a1a2e; letter-spacing: 2px; }
        .company-subtitle { font-size: 12px; color: #666; margin-top: 4px; }
        .invoice-title { text-align: right; }
        .invoice-title h2 { font-size: 24px; color: #1a1a2e; margin-bottom: 4px; }
        .invoice-title .order-number { font-size: 16px; color: #555; }
        .invoice-title .date { font-size: 13px; color: #888; margin-top: 4px; }

        .info-section { display: flex; justify-content: space-between; margin-bottom: 30px; }
        .info-block { width: 48%; }
        .info-block h4 { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: #888; margin-bottom: 8px; border-bottom: 1px solid #eee; padding-bottom: 4px; }
        .info-block p { margin: 3px 0; font-size: 13px; }
        .info-block .name { font-weight: 600; font-size: 14px; }

        table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
        thead th { background: #1a1a2e; color: #fff; padding: 10px 12px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
        thead th:first-child { text-align: left; }
        tbody td { padding: 10px 12px; border-bottom: 1px solid #eee; }
        tbody tr:hover { background: #f8f9fa; }
        .text-center { text-align: center; }
        .text-right { text-align: right; }

        .totals { margin-left: auto; width: 300px; }
        .totals table { margin-bottom: 0; }
        .totals td { padding: 6px 12px; border-bottom: 1px solid #eee; font-size: 13px; }
        .totals .label { color: #666; }
        .totals .grand-total td { font-size: 16px; font-weight: 700; color: #1a1a2e; border-top: 2px solid #1a1a2e; border-bottom: none; }
        .discount { color: #dc3545; }

        .footer { margin-top: 40px; padding-top: 20px; border-top: 1px solid #ddd; text-align: center; font-size: 12px; color: #888; }

        .status-badge { display: inline-block; padding: 4px 12px; border-radius: 4px; font-size: 12px; font-weight: 600; color: #fff; background: #6c757d; }
        .status-Pending { background: #ffc107; color: #333; }
        .status-Confirmed { background: #17a2b8; }
        .status-Processing { background: #6f42c1; }
        .status-Shipped { background: #0d6efd; }
        .status-Delivered { background: #198754; }
        .status-Cancelled { background: #dc3545; }

        @@media print {
            body { padding: 20px; }
            .no-print { display: none !important; }
            tbody tr:hover { background: transparent; }
        }
    </style>
</head>
<body>
    <div class="no-print" style="text-align:center; margin-bottom:20px;">
        <button onclick="window.print()" style="padding:10px 30px; font-size:15px; background:#1a1a2e; color:#fff; border:none; border-radius:6px; cursor:pointer;">
            Yazdir
        </button>
        <button onclick="window.close()" style="padding:10px 30px; font-size:15px; background:#6c757d; color:#fff; border:none; border-radius:6px; cursor:pointer; margin-left:8px;">
            Kapat
        </button>
    </div>

    <div class="invoice">
        <div class="header">
            <div>
                <div class="company-name">AVANSAS</div>
                <div class="company-subtitle">B2B / B2C E-Ticaret Platformu</div>
            </div>
            <div class="invoice-title">
                <h2>FATURA</h2>
                <div class="order-number">#@Model.OrderNumber</div>
                <div class="date">@Model.CreatedAt.ToString("dd MMMM yyyy, HH:mm", new System.Globalization.CultureInfo("tr-TR"))</div>
                <div style="margin-top:6px;">
                    <span class="status-badge status-@Model.Status">@Model.StatusText</span>
                </div>
            </div>
        </div>

        <div class="info-section">
            <div class="info-block">
                <h4>Musteri Bilgileri</h4>
                <p class="name">@Model.UserFullName</p>
                <p>@Model.UserEmail</p>
                <p>@Model.ShippingPhone</p>
            </div>
            <div class="info-block">
                <h4>Teslimat Adresi</h4>
                <p class="name">@Model.ShippingFirstName @Model.ShippingLastName</p>
                <p>@Model.ShippingAddress</p>
                <p>@Model.ShippingDistrict / @Model.ShippingCity</p>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th style="width:50%">Urun</th>
                    <th class="text-center" style="width:10%">Adet</th>
                    <th class="text-right" style="width:20%">Birim Fiyat</th>
                    <th class="text-right" style="width:20%">Toplam</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <strong>@item.ProductName</strong>
                            @if (!string.IsNullOrEmpty(item.ProductSKU))
                            {
                                <br /><span style="font-size:11px;color:#888;">SKU: @item.ProductSKU</span>
                            }
                        </td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-right">@item.UnitPrice.ToString("N2") &#8378;</td>
                        <td class="text-right">@item.TotalPrice.ToString("N2") &#8378;</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="totals">
            <table>
                <tr>
                    <td class="label">Ara Toplam</td>
                    <td class="text-right">@Model.SubTotal.ToString("N2") &#8378;</td>
                </tr>
                <tr>
                    <td class="label">Kargo</td>
                    <td class="text-right">@(Model.ShippingCost == 0 ? "Ucretsiz" : Model.ShippingCost.ToString("N2") + " \u20BA")</td>
                </tr>
                @if (Model.DiscountAmount > 0)
                {
                    <tr>
                        <td class="label">Indirim @(Model.CouponCode != null ? $"({Model.CouponCode})" : "")</td>
                        <td class="text-right discount">-@Model.DiscountAmount.ToString("N2") &#8378;</td>
                    </tr>
                }
                @if (Model.TaxAmount > 0)
                {
                    <tr>
                        <td class="label">Vergi (KDV)</td>
                        <td class="text-right">@Model.TaxAmount.ToString("N2") &#8378;</td>
                    </tr>
                }
                <tr class="grand-total">
                    <td>Genel Toplam</td>
                    <td class="text-right">@Model.Total.ToString("N2") &#8378;</td>
                </tr>
            </table>
        </div>

        @if (!string.IsNullOrEmpty(Model.Note))
        {
            <div style="margin-top:20px; padding:12px; background:#f8f9fa; border-radius:6px; font-size:13px;">
                <strong>Not:</strong> @Model.Note
            </div>
        }

        <div class="footer">
            <p>Bu belge @Model.CreatedAt.ToString("dd.MM.yyyy") tarihinde olusturulmustur.</p>
            <p style="margin-top:4px;">Avansas - B2B/B2C E-Ticaret Platformu</p>
        </div>
    </div>
</body>
</html>
