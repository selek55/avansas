@model Avansas.Application.DTOs.OrderDto
@{
    ViewData["Title"] = "Sipariş " + Model.OrderNumber;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-4">
    <!-- Sol: Sipariş Detayları -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Sipariş #@Model.OrderNumber</span>
                @{
                    var sBadge = Model.Status switch {
                        Avansas.Domain.Enums.OrderStatus.Pending => "warning",
                        Avansas.Domain.Enums.OrderStatus.Confirmed => "info",
                        Avansas.Domain.Enums.OrderStatus.Shipped => "primary",
                        Avansas.Domain.Enums.OrderStatus.Delivered => "success",
                        Avansas.Domain.Enums.OrderStatus.Cancelled => "danger",
                        _ => "secondary"
                    };
                }
                <span class="badge bg-@sBadge fs-6">@Model.StatusText</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ürün</th>
                                <th class="text-center">Adet</th>
                                <th class="text-end">Birim Fiyat</th>
                                <th class="text-end">Toplam</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="@(item.ProductImageUrl ?? "/images/no-image.png")"
                                                 style="width:40px;height:40px;object-fit:contain" />
                                            <div>
                                                <div class="fw-semibold small">@item.ProductName</div>
                                                <div class="text-muted" style="font-size:.75rem">@item.ProductSKU</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.UnitPrice.ToString("N2")₺</td>
                                    <td class="text-end fw-semibold">@item.TotalPrice.ToString("N2")₺</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr><td colspan="3" class="text-end text-muted small">Ara Toplam</td><td class="text-end">@Model.SubTotal.ToString("N2")₺</td></tr>
                            <tr><td colspan="3" class="text-end text-muted small">Kargo</td><td class="text-end">@(Model.ShippingCost == 0 ? "Ücretsiz" : Model.ShippingCost.ToString("N2") + "₺")</td></tr>
                            @if (Model.DiscountAmount > 0) {
                                <tr><td colspan="3" class="text-end text-muted small">İndirim (@Model.CouponCode)</td><td class="text-end text-danger">-@Model.DiscountAmount.ToString("N2")₺</td></tr>
                            }
                            <tr><td colspan="3" class="text-end fw-bold">Genel Toplam</td><td class="text-end fw-bold fs-5">@Model.Total.ToString("N2")₺</td></tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Durum Güncelle -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">Durum Güncelle</div>
            <div class="card-body">
                <form method="post" action="/admin/orders/updatestatus">
                    <input type="hidden" name="OrderId" value="@Model.Id" />
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Durum</label>
                            <select name="Status" class="form-select">
                                @foreach (var s in Enum.GetValues<Avansas.Domain.Enums.OrderStatus>())
                                {
                                    <option value="@((int)s)" selected="@(s == Model.Status ? "selected" : null)">
                                        @s
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Kargo Firması</label>
                            <input type="text" name="CargoCompany" class="form-control"
                                   value="@Model.CargoCompany" placeholder="MNG, Yurtiçi..." />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Takip No</label>
                            <input type="text" name="CargoTrackingNumber" class="form-control"
                                   value="@Model.CargoTrackingNumber" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary mt-3">
                        <i class="fas fa-save me-2"></i> Güncelle
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Sağ: Müşteri & Adres -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold">Müşteri</div>
            <div class="card-body">
                <p class="fw-semibold mb-1">@Model.UserFullName</p>
                <p class="text-muted small mb-0">@Model.UserEmail</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold">Teslimat Adresi</div>
            <div class="card-body">
                <p class="small mb-1">@Model.ShippingAddress</p>
                <p class="small text-muted mb-0">@Model.ShippingCity</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold">Kargo Oluştur</div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.CargoTrackingNumber))
                {
                    <p class="text-success small mb-2">
                        <i class="fas fa-check-circle me-1"></i>@Model.CargoCompany — @Model.CargoTrackingNumber
                    </p>
                    @if (Model.ShippedAt.HasValue)
                    {
                        <p class="text-muted small mb-0">Gönderildi: @Model.ShippedAt.Value.ToString("dd.MM.yyyy")</p>
                    }
                }
                else
                {
                    <form method="post" action="/admin/orders/@Model.Id/create-shipment">
                        @Html.AntiForgeryToken()
                        <div class="mb-2">
                            <select name="cargoCompany" class="form-select form-select-sm">
                                <option value="0">Yurtiçi Kargo</option>
                                <option value="1">Aras Kargo</option>
                                <option value="2">MNG Kargo</option>
                                <option value="3">PTT Kargo</option>
                                <option value="4">Sürat Kargo</option>
                            </select>
                        </div>
                        <div class="mb-2">
                            <input type="text" name="trackingNumber" class="form-control form-control-sm"
                                   placeholder="Takip numarası" required />
                        </div>
                        <button type="submit" class="btn btn-sm btn-primary w-100">
                            <i class="fas fa-truck me-1"></i>Kargoya Ver
                        </button>
                    </form>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">Ödeme Bilgisi</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-6 text-muted">Yöntem</dt>
                    <dd class="col-6">@Model.PaymentMethodText</dd>
                    <dt class="col-6 text-muted">Durum</dt>
                    <dd class="col-6">
                        @{
                            var pBadge = Model.PaymentStatus switch {
                                Avansas.Domain.Enums.PaymentStatus.Paid => "success",
                                Avansas.Domain.Enums.PaymentStatus.Failed => "danger",
                                _ => "warning"
                            };
                        }
                        <span class="badge bg-@pBadge">@Model.PaymentStatusText</span>
                    </dd>
                    <dt class="col-6 text-muted">Tarih</dt>
                    <dd class="col-6">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a href="/admin/orders" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i> Geri
    </a>
    <a href="/admin/orders/printinvoice/@Model.Id" target="_blank" class="btn btn-outline-primary">
        <i class="fas fa-print me-2"></i> Fatura Yazdir
    </a>
</div>
