@model IEnumerable<Avansas.Domain.Entities.PaymentTransaction>
@{
    ViewData["Title"] = "Ödeme İşlemleri";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="fas fa-credit-card me-2"></i>Ödeme İşlemleri</h4>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Sipariş</th>
                        <th>Tutar</th>
                        <th>Ödenen</th>
                        <th>Durum</th>
                        <th>Kart</th>
                        <th>Tarih</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        var badge = t.Status switch {
                            Avansas.Domain.Enums.PaymentTransactionStatus.Success => "success",
                            Avansas.Domain.Enums.PaymentTransactionStatus.Failed => "danger",
                            Avansas.Domain.Enums.PaymentTransactionStatus.Pending3DSecure => "warning",
                            Avansas.Domain.Enums.PaymentTransactionStatus.Refunded => "info",
                            Avansas.Domain.Enums.PaymentTransactionStatus.PartialRefund => "secondary",
                            _ => "light"
                        };
                        <tr>
                            <td><small class="text-muted">#@t.Id</small></td>
                            <td><a href="/admin/orders/@t.OrderId" class="text-decoration-none">#@t.OrderId</a></td>
                            <td>@t.Amount.ToString("N2")₺</td>
                            <td>@t.PaidAmount.ToString("N2")₺</td>
                            <td><span class="badge bg-@badge">@t.Status</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(t.CardLastFour))
                                {
                                    <span>**** @t.CardLastFour</span>
                                }
                            </td>
                            <td><small>@t.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small></td>
                            <td>
                                <a href="/admin/payments/@t.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
