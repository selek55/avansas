@model Avansas.Application.DTOs.CreateWarehouseDto
@{
    ViewData["Title"] = "Yeni Depo";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Depo Adı</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Şehir</label>
                    <input asp-for="City" class="form-control" />
                </div>
                <div class="col-md-12">
                    <label class="form-label fw-semibold">Adres</label>
                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Telefon</label>
                    <input asp-for="Phone" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Durum</label>
                    <select asp-for="IsActive" class="form-select">
                        <option value="true">Aktif</option>
                        <option value="false">Pasif</option>
                    </select>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Kaydet</button>
                <a href="/admin/warehouses" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>
