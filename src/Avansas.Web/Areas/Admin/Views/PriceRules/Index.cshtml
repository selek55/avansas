@model List<Avansas.Application.DTOs.PriceRuleDto>
@{
    ViewData["Title"] = "Fiyat Kuralları";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div></div>
    <a href="/admin/pricerules/create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i> Yeni Fiyat Kuralı
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Ad</th>
                        <th>Tür</th>
                        <th>İndirim</th>
                        <th>Hedef</th>
                        <th>Tarih Aralığı</th>
                        <th>Öncelik</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rule in Model)
                    {
                        var target = rule.ProductName ?? rule.CategoryName ?? rule.BrandName ?? rule.CustomerGroup ?? "Genel";
                        <tr>
                            <td>
                                <div class="fw-semibold">@rule.Name</div>
                                @if (!string.IsNullOrEmpty(rule.Description))
                                {
                                    <small class="text-muted">@rule.Description</small>
                                }
                            </td>
                            <td><span class="badge bg-info">@rule.Type</span></td>
                            <td>
                                @if (rule.IsPercentage)
                                {
                                    <span class="fw-bold text-success">%@rule.DiscountValue</span>
                                }
                                else
                                {
                                    <span class="fw-bold text-success">@rule.DiscountValue.ToString("N2") TL</span>
                                }
                            </td>
                            <td>@target</td>
                            <td>
                                @if (rule.StartDate.HasValue || rule.EndDate.HasValue)
                                {
                                    <small>@(rule.StartDate?.ToString("dd.MM.yyyy") ?? "...") - @(rule.EndDate?.ToString("dd.MM.yyyy") ?? "...")</small>
                                }
                                else
                                {
                                    <small class="text-muted">Süresiz</small>
                                }
                            </td>
                            <td><span class="badge bg-secondary">@rule.Priority</span></td>
                            <td>
                                <form method="post" action="/admin/pricerules/toggleactive" class="d-inline">
                                    <input type="hidden" name="id" value="@rule.Id" />
                                    <button type="submit" class="btn btn-sm @(rule.IsActive ? "btn-success" : "btn-outline-secondary")">
                                        @(rule.IsActive ? "Aktif" : "Pasif")
                                    </button>
                                </form>
                            </td>
                            <td class="text-end">
                                <a href="/admin/pricerules/edit/@rule.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="/admin/pricerules/delete" class="d-inline"
                                      onsubmit="return confirm('Bu kuralı silmek istediğinize emin misiniz?')">
                                    <input type="hidden" name="id" value="@rule.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Henüz fiyat kuralı eklenmemiş.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
