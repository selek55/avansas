@model List<BlogPostDto>
@{
    ViewData["Title"] = "Blog Yazıları";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div></div>
    <a href="/admin/blog/create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i> Yeni Yazı Ekle
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <span class="text-muted small">Toplam <strong>@Model.Count</strong> yazı</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Başlık</th>
                        <th>Kategori</th>
                        <th>Yazar</th>
                        <th>Yayın</th>
                        <th>Görüntülenme</th>
                        <th>Tarih</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in Model)
                    {
                        <tr>
                            <td>
                                <strong>@post.Title</strong>
                                <br /><small class="text-muted">/@post.Slug</small>
                            </td>
                            <td>@(post.CategoryName ?? "-")</td>
                            <td>@post.AuthorName</td>
                            <td>
                                @if (post.IsPublished)
                                {
                                    <span class="badge bg-success">Yayında</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Taslak</span>
                                }
                            </td>
                            <td>@post.ViewCount</td>
                            <td class="text-muted small">@post.CreatedAt.ToString("dd.MM.yy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/admin/blog/edit/@post.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" action="/admin/blog/delete/@post.Id"
                                          onsubmit="return confirm('Bu yazıyı silmek istediğinizden emin misiniz?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
