@model List<Avansas.Application.DTOs.ReturnRequestDto>
@{
    ViewData["Title"] = "İade Talepleri";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- Status Tabs -->
<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link @(ViewBag.CurrentStatus == null ? "active" : "")" href="/admin/returns">Tümü (@Model.Count)</a>
    </li>
    @foreach (var (status, label, icon) in new[]{
        (Avansas.Domain.Enums.ReturnStatus.Pending, "Beklemede", "clock"),
        (Avansas.Domain.Enums.ReturnStatus.Approved, "Onaylanan", "check"),
        (Avansas.Domain.Enums.ReturnStatus.Rejected, "Reddedilen", "times"),
        (Avansas.Domain.Enums.ReturnStatus.Refunded, "İade Edilen", "undo"),
        (Avansas.Domain.Enums.ReturnStatus.Cancelled, "İptal", "ban"),
    })
    {
        <li class="nav-item">
            <a class="nav-link @(ViewBag.CurrentStatus?.ToString() == status.ToString() ? "active" : "")"
               href="/admin/returns?status=@((int)status)">
                <i class="fas fa-@icon me-1"></i> @label
            </a>
        </li>
    }
</ul>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>#</th>
                        <th>Sipariş No</th>
                        <th>Müşteri</th>
                        <th>Sebep</th>
                        <th>Tutar</th>
                        <th>Durum</th>
                        <th>Tarih</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                <i class="fas fa-inbox fa-2x mb-2 d-block"></i>Kayıt bulunamadı.
                            </td>
                        </tr>
                    }
                    @foreach (var ret in Model)
                    {
                        var badgeClass = ret.Status switch {
                            Avansas.Domain.Enums.ReturnStatus.Pending => "warning",
                            Avansas.Domain.Enums.ReturnStatus.Approved => "info",
                            Avansas.Domain.Enums.ReturnStatus.Rejected => "danger",
                            Avansas.Domain.Enums.ReturnStatus.Refunded => "success",
                            Avansas.Domain.Enums.ReturnStatus.Cancelled => "secondary",
                            _ => "secondary"
                        };
                        <tr>
                            <td>@ret.Id</td>
                            <td><span class="fw-semibold">@ret.OrderNumber</span></td>
                            <td>@ret.UserFullName</td>
                            <td class="text-truncate" style="max-width:200px;">@ret.Reason</td>
                            <td class="fw-bold">@ret.RefundAmount.ToString("N2") ₺</td>
                            <td><span class="badge bg-@badgeClass">@ret.StatusText</span></td>
                            <td class="text-muted small">@ret.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <a href="/admin/returns/detail/@ret.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
