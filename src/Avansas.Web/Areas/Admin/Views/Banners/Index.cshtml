@using Avansas.Application.DTOs
@model List<BannerDto>
@{
    ViewData["Title"] = "Bannerlar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Bannerlar</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Yeni Banner</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Görsel</th>
                    <th>Başlık</th>
                    <th>Sıra</th>
                    <th>Geçerlilik</th>
                    <th>Durum</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td>
                            <img src="@b.ImageUrl" style="height:48px;object-fit:cover;border-radius:4px;" alt="@b.Title" />
                        </td>
                        <td>
                            <div class="fw-semibold">@b.Title</div>
                            @if (!string.IsNullOrEmpty(b.SubTitle))
                            {
                                <div class="text-muted small">@b.SubTitle</div>
                            }
                        </td>
                        <td>@b.DisplayOrder</td>
                        <td class="small text-muted">
                            @(b.ValidFrom.HasValue ? b.ValidFrom.Value.ToString("dd.MM.yy") : "—")
                            — @(b.ValidTo.HasValue ? b.ValidTo.Value.ToString("dd.MM.yy") : "∞")
                        </td>
                        <td>
                            @if (b.IsActive)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pasif</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" asp-action="Toggle" asp-route-id="@b.Id">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-warning"><i class="fas fa-power-off"></i></button>
                                </form>
                                <form method="post" asp-action="Delete" asp-route-id="@b.Id"
                                      onsubmit="return confirm('Bu banner silinsin mi?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Banner bulunamadı.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
