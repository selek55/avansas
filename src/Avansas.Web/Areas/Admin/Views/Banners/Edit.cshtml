@model Avansas.Application.DTOs.UpdateBannerDto
@{
    ViewData["Title"] = "Banner Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Banner Düzenle</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Geri</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Başlık *</label>
                    <input asp-for="Title" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Alt Başlık</label>
                    <input asp-for="SubTitle" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Görsel URL *</label>
                    <input asp-for="ImageUrl" class="form-control" required />
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="mt-2 rounded" style="max-height:80px;" alt="Önizleme" />
                    }
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Mobil Görsel URL</label>
                    <input asp-for="MobileImageUrl" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Link URL</label>
                    <input asp-for="LinkUrl" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Buton Metni</label>
                    <input asp-for="ButtonText" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Görüntüleme Sırası</label>
                    <input asp-for="DisplayOrder" type="number" min="0" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Başlangıç Tarihi</label>
                    <input asp-for="ValidFrom" type="datetime-local" class="form-control"
                           value="@(Model.ValidFrom.HasValue ? Model.ValidFrom.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Bitiş Tarihi</label>
                    <input asp-for="ValidTo" type="datetime-local" class="form-control"
                           value="@(Model.ValidTo.HasValue ? Model.ValidTo.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4">Güncelle</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">İptal</a>
            </div>
        </form>
    </div>
</div>
