@model PagedResult<TicketDto>
@{
    ViewData["Title"] = "Destek Talepleri";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var currentStatus = ViewBag.CurrentStatus as TicketStatus?;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div></div>
    <span class="text-muted small">Toplam <strong>@Model.TotalCount</strong> talep</span>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">Tüm Durumlar</option>
                    <option value="Open" selected="@(currentStatus == TicketStatus.Open ? "selected" : null)">Açık</option>
                    <option value="InProgress" selected="@(currentStatus == TicketStatus.InProgress ? "selected" : null)">İşlemde</option>
                    <option value="WaitingCustomer" selected="@(currentStatus == TicketStatus.WaitingCustomer ? "selected" : null)">Müşteri Bekleniyor</option>
                    <option value="Resolved" selected="@(currentStatus == TicketStatus.Resolved ? "selected" : null)">Çözüldü</option>
                    <option value="Closed" selected="@(currentStatus == TicketStatus.Closed ? "selected" : null)">Kapatıldı</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filtrele</button>
            </div>
            <div class="col-md-2">
                <a href="/admin/tickets" class="btn btn-outline-secondary w-100">Temizle</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Konu</th>
                        <th>Kullanıcı</th>
                        <th>Durum</th>
                        <th>Öncelik</th>
                        <th>Mesaj</th>
                        <th>Tarih</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Items)
                    {
                        <tr>
                            <td class="text-muted">@t.Id</td>
                            <td>
                                <a href="/admin/tickets/detail/@t.Id" class="text-decoration-none fw-semibold">@t.Subject</a>
                                @if (t.OrderNumber != null)
                                {
                                    <br /><small class="text-muted">Sipariş: @t.OrderNumber</small>
                                }
                            </td>
                            <td>
                                @t.UserFullName
                                <br /><small class="text-muted">@t.UserEmail</small>
                            </td>
                            <td>
                                @switch (t.Status)
                                {
                                    case TicketStatus.Open:
                                        <span class="badge bg-info">Açık</span>
                                        break;
                                    case TicketStatus.InProgress:
                                        <span class="badge bg-primary">İşlemde</span>
                                        break;
                                    case TicketStatus.WaitingCustomer:
                                        <span class="badge bg-warning text-dark">Müşteri Bekleniyor</span>
                                        break;
                                    case TicketStatus.Resolved:
                                        <span class="badge bg-success">Çözüldü</span>
                                        break;
                                    case TicketStatus.Closed:
                                        <span class="badge bg-secondary">Kapatıldı</span>
                                        break;
                                }
                            </td>
                            <td>
                                @switch (t.Priority)
                                {
                                    case TicketPriority.Low:
                                        <span class="badge bg-secondary">Düşük</span>
                                        break;
                                    case TicketPriority.Normal:
                                        <span class="badge bg-info">Normal</span>
                                        break;
                                    case TicketPriority.High:
                                        <span class="badge bg-warning text-dark">Yüksek</span>
                                        break;
                                    case TicketPriority.Urgent:
                                        <span class="badge bg-danger">Acil</span>
                                        break;
                                }
                            </td>
                            <td>@t.MessageCount</td>
                            <td class="text-muted small">@t.CreatedAt.ToString("dd.MM.yy HH:mm")</td>
                            <td>
                                <a href="/admin/tickets/detail/@t.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-white">
            <nav><ul class="pagination pagination-sm mb-0 justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" href="/admin/tickets?page=@i@(currentStatus != null ? $"&status={currentStatus}" : "")">@i</a>
                    </li>
                }
            </ul></nav>
        </div>
    }
</div>
