@model Avansas.Application.DTOs.UserDto
@{
    ViewData["Title"] = Model.FullName;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center mb-3"
                     style="width:72px;height:72px">
                    <span class="text-white fs-3 fw-bold">@Model.FirstName[0]</span>
                </div>
                <h5 class="fw-bold mb-1">@Model.FullName</h5>
                <p class="text-muted small mb-2">@Model.Email</p>
                @foreach (var role in Model.Roles)
                {
                    <span class="badge @(role == "Admin" ? "bg-danger" : "bg-secondary") me-1">@role</span>
                }
                <hr />
                <div class="row text-center">
                    <div class="col-6">
                        <div class="fs-5 fw-bold text-primary">@Model.OrderCount</div>
                        <div class="text-muted small">Sipariş</div>
                    </div>
                    <div class="col-6">
                        <div class="fs-5 fw-bold text-success">@Model.TotalSpent.ToString("N0")₺</div>
                        <div class="text-muted small">Harcama</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">Kullanıcı Bilgileri</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted small">Ad Soyad</dt>
                    <dd class="col-sm-8">@Model.FullName</dd>

                    <dt class="col-sm-4 text-muted small">E-posta</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4 text-muted small">Telefon</dt>
                    <dd class="col-sm-8">@(Model.PhoneNumber ?? "—")</dd>

                    <dt class="col-sm-4 text-muted small">Hesap Türü</dt>
                    <dd class="col-sm-8">@(Model.IsCorporate ? "Kurumsal" : "Bireysel")</dd>

                    @if (Model.IsCorporate)
                    {
                        <dt class="col-sm-4 text-muted small">Şirket</dt>
                        <dd class="col-sm-8">@Model.CompanyName</dd>
                    }

                    <dt class="col-sm-4 text-muted small">Durum</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">
                            @(Model.IsActive ? "Aktif" : "Pasif")
                        </span>
                    </dd>

                    <dt class="col-sm-4 text-muted small">Kayıt Tarihi</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="/admin/users" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i> Geri
    </a>
</div>
