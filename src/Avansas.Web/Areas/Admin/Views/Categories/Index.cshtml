@model IEnumerable<Avansas.Application.DTOs.CategoryDto>
@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div></div>
    <a href="/admin/categories/create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i> Yeni Kategori
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <span class="text-muted small">Toplam <strong>@Model.Count()</strong> kategori</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Kategori Adı</th>
                        <th>Üst Kategori</th>
                        <th>Sıra</th>
                        <th>Ürün Sayısı</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in Model.OrderBy(c => c.DisplayOrder))
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@cat.Name</div>
                                <div class="text-muted small">@cat.Slug</div>
                            </td>
                            <td class="text-muted small">@(cat.ParentCategoryName ?? "—")</td>
                            <td>@cat.DisplayOrder</td>
                            <td><span class="badge bg-light text-dark">@cat.ProductCount</span></td>
                            <td>
                                <span class="badge @(cat.IsActive ? "bg-success" : "bg-secondary")">
                                    @(cat.IsActive ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/admin/categories/edit/@cat.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" action="/admin/categories/delete/@cat.Id"
                                          onsubmit="return confirm('Silmek istediğinizden emin misiniz?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
