@model Avansas.Application.DTOs.CreateCategoryDto
@{
    ViewData["Title"] = "Yeni Kategori";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label fw-semibold">Kategori Adı *</label>
                            <input asp-for="Name" class="form-control" placeholder="Kategori adını girin" id="nameInput" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Slug" class="form-label fw-semibold">
                                Slug <small class="text-muted fw-normal">(URL adresi — otomatik doldurulur)</small>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text text-muted small">/kategori/</span>
                                <input asp-for="Slug" class="form-control" id="slugInput" placeholder="kategori-adi" />
                            </div>
                            <div class="mt-1 small">
                                <span class="text-muted">Önizleme: </span>
                                <a id="slugPreview" href="#" target="_blank" class="text-primary text-decoration-none fst-italic">/kategori/</a>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="ParentCategoryId" class="form-label fw-semibold">Üst Kategori</label>
                            <select asp-for="ParentCategoryId" asp-items="ViewBag.ParentCategories" class="form-select">
                                <option value="">Ana kategori (üst yok)</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold">Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="ImageUrl" class="form-label fw-semibold">Görsel URL</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="/images/categories/..." />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DisplayOrder" class="form-label fw-semibold">Sıra</label>
                            <input asp-for="DisplayOrder" class="form-control" type="number" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label">Aktif</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="fas fa-save me-2"></i> Kaydet
                        </button>
                        <a href="/admin/categories" class="btn btn-outline-secondary px-4">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    const nameEl = document.getElementById('nameInput');
    const slugEl = document.getElementById('slugInput');
    let manual = false;

    function toSlug(v) {
        return v.toLowerCase()
            .replace(/ş/g,'s').replace(/ğ/g,'g').replace(/ü/g,'u')
            .replace(/ö/g,'o').replace(/ç/g,'c').replace(/ı/g,'i').replace(/İ/g,'i')
            .replace(/\s+/g,'-').replace(/[^a-z0-9\-]/g,'').replace(/-+/g,'-');
    }
    const preview = document.getElementById('slugPreview');
    function updatePreview(slug) { preview.textContent = '/kategori/' + (slug || '...'); preview.href = '/kategori/' + slug; }
    nameEl.addEventListener('input', () => { if (!manual) { slugEl.value = toSlug(nameEl.value); updatePreview(slugEl.value); } });
    slugEl.addEventListener('input', () => { manual = slugEl.value !== ''; slugEl.value = toSlug(slugEl.value); updatePreview(slugEl.value); });
    updatePreview(slugEl.value);
})();
</script>
}
